{
  "name": "deskcall",
  "version": "0.1.0",
  "description": "DeskCall Windows Bluetooth hands-free calling desktop app",
  "main": "dist-electron/main.js",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "build": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1",
    "dev:ui": "vite --host 127.0.0.1",
    "electron:dev": "tsc -p tsconfig.electron.json && electron .",
    "build:ui": "tsc -p tsconfig.json && vite build && tsc -p tsconfig.electron.json",
    "build:helper": "dotnet build native/DeskCall.Helper/DeskCall.Helper.csproj -c Debug",
    "publish:helper": "dotnet publish native/DeskCall.Helper/DeskCall.Helper.csproj -c Release -r win-x64 --self-contained false -o dist-native/DeskCall.Helper"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.4.6",
    "lucide-react": "^0.468.0",
    "vite": "^5.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
